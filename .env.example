PORT=5000
MONGO_URI=mongodb://localhost:27017/fitnessbyajeet
JWT_SECRET=your_jwt_secret_here

# Cloudinary (for image/video uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Twilio (for WhatsApp notifications)
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Use your Twilio sandbox number during testing, or your approved WhatsApp sender
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Admin WhatsApp number for enquiries
ADMIN_WHATSAPP=+919999999999

# Email (for notifications)
EMAIL_USER=your@email.com
EMAIL_PASS=your_email_password

# Vercel Cron secret — set this to a random string and add it in Vercel env vars too
# Vercel will send it as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your_random_cron_secret_here

# CORS — comma-separated list of allowed frontend origins
# Example: https://gym-web-ten-puce.vercel.app,https://yourdomain.com
# Leave empty to allow ALL origins (local dev only)
ALLOWED_ORIGINS=https://gym-web-ten-puce.vercel.app
